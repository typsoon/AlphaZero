{
  "name": "gameplay_server",
  "version": "1.0.0",
  "description": "Player vs AlphaZero - Vue TypeScript Client",
  "license": "MIT",
  "author": "",
  "type": "module",
  "main": "server.ts",
  "scripts": {
    "test": "npm run clean:tests && npm run build && npm run build:tests && node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand dist-tests/__tests__/",
    "build": "tsc -p tsconfig.json",
    "build:tests": "tsc -p tsconfig.tests.json",
    "clean:tests": "find __tests__ -type f \\( -name '*.js' -o -name '*.js.map' -o -name '*.d.ts' -o -name '*.d.ts.map' \\) -delete && rm -rf dist-tests",
    "start": "npm run build && node dist/server.js",
    "dev": "nodemon server",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint ."
  },
  "dependencies": {
    "@fastify/websocket": "^11.0.1",
    "better-sqlite3": "^12.11.1",
    "fastify": "^5.8.4",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.6.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.0.0",
    "fastify-swagger": "^5.1.1",
    "jest": "^29.7.0",
    "jiti": "^2.7.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.0.0",
    "typescript-eslint": "^8.0.0"
  }
}
